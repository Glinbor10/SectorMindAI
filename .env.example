# Variables de entorno para Docker y producción
# SectorMindAI - Configuración centralizada

# URLs de servicios (Docker Compose)
API_URL=http://backend:5000
RASA_URL=http://rasa:5005

# Base de datos PostgreSQL
DATABASE_URL=postgresql://sectormind:your_password@db:5432/sectormind_db
DATABASE_URL_TEST=postgresql://sectormind:your_password@db:5432/sectormind_test_db
POSTGRES_USER=sectormind
POSTGRES_PASSWORD=your_password
POSTGRES_DB=sectormind_db
POSTGRES_DB_TEST=sectormind_test_db

# Credenciales de administración
ADMIN_PASSWORD=your_secure_admin_password

# Configuración de entorno
FLASK_ENV=production
FLASK_PORT=5000